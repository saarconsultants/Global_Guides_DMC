# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- Session ---
# A long random string used to encrypt the session cookie (min 32 chars).
# Generate one with: `openssl rand -base64 48`
SESSION_PASSWORD=replace-with-min-32-char-random-string-generated-via-openssl-rand

# --- Tripjack ---
# Account: GLOBALGUIDES DMC LLP (User ID 113003)
# Panel:   https://apitest.tripjack.com/  → Manage User → API Configuration
#          (whitelist your IP first; copy the API key immediately as it gets masked)
# Production base URL once you go live: https://tripjack.com
TRIPJACK_BASE_URL=https://apitest.tripjack.com
TRIPJACK_API_KEY=

# --- OpenRouter (for AI Suggester) ---
# Get a key at https://openrouter.ai/keys
# Leave blank to disable the AI Suggester (the modal shows a "key not set" message).
OPENROUTER_API_KEY=
# Model (default: free Llama 3.3 70B Instruct — fast, accurate, non-reasoning).
# Any OpenRouter model id works; browse free ones at
# https://openrouter.ai/models?output_modalities=text&max_price=0
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional reasoning effort, ONLY for reasoning-native models like Nemotron
# (low | medium | high). Leave UNSET for non-reasoning models like Llama.
# OPENROUTER_REASONING_EFFORT=low

# --- Database ---
# Dev (SQLite, zero-install — just a file):
DATABASE_URL="file:./dev.db"
# Prod (Postgres, set on Vercel):
# DATABASE_URL="postgresql://user:password@host:5432/globalguides?sslmode=require"

# --- Error monitoring (optional, Tier 5) ---
# All server errors are always logged to the Vercel runtime logs. Setting a
# Sentry DSN additionally forwards them to Sentry for alerting + grouping.
# To enable: `cd apps/web && npm i @sentry/nextjs`, then set both DSNs + redeploy.
# Leave blank to keep console/Vercel-logs-only (no extra dependency needed).
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# Optional: post new bug reports to a Slack channel (Incoming Webhook URL).
# SLACK_BUG_WEBHOOK=
