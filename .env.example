# ─────────────────────────────────────────────────────────────────────────────
# Global Guides — Environment template
# Copy to .env.local for local dev. In Vercel, set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──
# Local dev: a Neon dev branch or a local Postgres docker container
# Production: Neon prod branch (use the "Pooled connection" string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Auth session (REQUIRED) ──
# Generate a 64-char random string. Used to encrypt the iron-session cookie.
# `openssl rand -base64 48` works.
SESSION_PASSWORD="REPLACE_ME_WITH_64_CHARS_OF_RANDOM_STRING_FROM_OPENSSL_RAND_BASE64_48"

# ── App URL (REQUIRED in prod, optional local) ──
# Used by the lead-widget snippet generator + share links.
# Vercel auto-sets VERCEL_URL but it changes per deploy — use a stable custom domain in prod.
NEXT_PUBLIC_APP_URL="https://globalguides.app"

# ── Tripjack (flights) ──
# Two modes:
#
# DIRECT MODE (local dev, your home IP is whitelisted):
#   TRIPJACK_BASE_URL = https://apitest.tripjack.com
#   TRIPJACK_API_KEY  = <real key>
#   TRIPJACK_PROXY_TOKEN = (leave blank)
#
# PROXY MODE (Vercel — calls go through Railway proxy with static IP):
#   TRIPJACK_BASE_URL = https://YOUR-PROXY.up.railway.app/tripjack
#   TRIPJACK_API_KEY  = (leave blank — proxy injects it)
#   TRIPJACK_PROXY_TOKEN = <shared secret matching proxy's PROXY_AUTH_TOKEN>
#
# Without any of these, the adapter returns mock data — still fine for UX testing.
TRIPJACK_BASE_URL="https://apitest.tripjack.com"
TRIPJACK_API_KEY=""
TRIPJACK_PROXY_TOKEN=""

# ── Anthropic (AI Itinerary Suggester) ──
# Without this, AI suggester returns a graceful fallback message.
ANTHROPIC_API_KEY=""

# ── Bug-report alerts (OPTIONAL) ──
# If set, every new BugReport pings this Slack incoming webhook.
SLACK_BUG_WEBHOOK=""
